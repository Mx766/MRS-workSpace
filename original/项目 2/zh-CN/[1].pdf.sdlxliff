26 01:34:58</sdl:value><sdl:value key="last_modified_by">MX982\21551</sdl:value><sdl:value key="modified_on">06/25/2026 01:35:21</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="7"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="0d49ba3b-f398-412a-823c-25cd7467b043"><source><x id="23"/><g id="26">KEYWORDS</g></source><seg-source><mrk mtype="seg" mid="4"><x id="23"/><g id="26">KEYWORDS</g></mrk></seg-source><target><mrk mtype="seg" mid="4"><x id="23"/>关键词</mrk></target><sdl:seg-defs><sdl:seg id="4" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">vse10pB4L+yE5GXsY+WXnpqUn8/O6icCVyCIXYpYCbE=</sdl:value><sdl:value key="created_by">MX982\21551</sdl:value><sdl:value key="created_on">06/25/2026 01:35:29</sdl:value><sdl:value key="last_modified_by">MX982\21551</sdl:value><sdl:value key="modified_on">06/25/2026 01:35:33</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="8"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="4b1ac703-adf7-490d-925d-f3726f465ad1"><source><g id="29"> Noninvasive skin tightening  Ulthera  Microfocused ultrasound  Thermal injury zones</g></source><seg-source><g id="29"> <mrk mtype="seg" mid="5">Noninvasive skin tightening  Ulthera  Microfocused ultrasound  Thermal injury zones</mrk></g></seg-source><target><g id="29"> <mrk mtype="seg" mid="5">非侵入性皮肤紧致 Ulthera  微聚焦超声 热损伤区</mrk></g></target><sdl:seg-defs><sdl:seg id="5" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">lU3Ce9IQ80GSM5SqXiBVsbZzdTgk1smQTmimfyilpDs=</sdl:value><sdl:value key="created_by">MX982\21551</sdl:value><sdl:value key="created_on">06/25/2026 01:35:46</sdl:value><sdl:value key="last_modified_by">MX982\21551</sdl:value><sdl:value key="modified_on">06/25/2026 01:36:45</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="9"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="f377a3cb-a3e0-4286-b4de-f0d87e52ab3f"><source><g id="53">KEY POINTS</g></source><seg-source><g id="53"><mrk mtype="seg" mid="6">KEY POINTS</mrk></g></seg-source><target><g id="53"><mrk mtype="seg" mid="6">关键点</mrk></g></target><sdl:seg-defs><sdl:seg id="6" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">DtOIJayJ/oyo1ZvJI4u28Bb7u3S8gouuPtVtQB8RJVI=</sdl:value><sdl:value key="created_by">MX982\21551</sdl:value><sdl:value key="created_on">06/25/2026 01:36:51</sdl:value><sdl:value key="last_modified_by">MX982\21551</sdl:value><sdl:value key="modified_on">06/25/2026 01:36:56</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="10"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="33d4f3c8-54dc-4996-b3ef-f5b258db2f05"><source><g id="56">  Noninvasive  skin  tightening  is  possible  in  one  treatment  session  using  Ulthera  microfocused ultrasound.</g></source><seg-source><g id="56">  <mrk mtype="seg" mid="7">Noninvasive  skin  tightening  is  possible  in  one  treatment  session  using  Ulthera  microfocused ultrasound.</mrk></g></seg-source><target><g id="56">  <mrk mtype="seg" mid="7">使用Ulthera微聚焦超声，单次治疗即可实现非侵入性皮肤紧致。</mrk></g></target><sdl:seg-defs><sdl:seg id="7" conf="Translated" origin="interactive"><sdl:value key="SegmentIdentityHash">yDR8pdue4a/Qz1qljANcMruQipB1e2Mfv790A1v+s6o=</sdl:value><sdl:value key="created_by">MX982\21551</sdl:value><sdl:value key="created_on">06/25/2026 01:37:10</sdl:value><sdl:value key="last_modified_by">MX982\21551</sdl:value><sdl:value key="modified_on">06/25/2026 01:37:16</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="11"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="704df7ce-0e36-4361-9ef0-086398e5dcf5"><source><g id="59">  Results may not be seen until 3 to 6 months after treatment.</g></source><seg-source><g id="59">  <mrk mtype="seg" mid="8">Results may not be seen until 3 to 6 months after treatment.</mrk></g></seg-source><target><g id="59">  <mrk mtype="seg" mid="8"/></g></target><sdl:seg-defs><sdl:seg id="8"><sdl:value key="SegmentIdentityHash">U+UwK5vjH+HtC13sdepmlyS9a5sMk829MtskgHdacEw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="12"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="45802083-db8c-4a77-9b49-7cb7229c22f2"><source><g id="62">  Some patients may not see improvement after treatment depending on individual patient treatment response and the energy delivery protocols used.</g></source><seg-source><g id="62">  <mrk mtype="seg" mid="9">Some patients may not see improvement after treatment depending on individual patient treatment response and the energy delivery protocols used.</mrk></g></seg-source><target><g id="62">  <mrk mtype="seg" mid="9"/></g></target><sdl:seg-defs><sdl:seg id="9"><sdl:value key="SegmentIdentityHash">ymRA4UV9pb/s+J7oalR+YKCkhv8AL8n20uUccWPFIW8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="13"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="611a2b70-fd70-49b4-b77e-e1780d033c43"><source><g id="65">INTRODUCTION</g></source><seg-source><g id="65"><mrk mtype="seg" mid="10">INTRODUCTION</mrk></g></seg-source><target><g id="65"><mrk mtype="seg" mid="10"/></g></target><sdl:seg-defs><sdl:seg id="10"><sdl:value key="SegmentIdentityHash">qoTUKtrSyGAfQ6XdW12nwXk7MAyh/kdLD8BLG6JEtX4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="14"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="3b6c67fa-6560-4780-bcef-9095910deb63"><source><g id="68">The continued patient demand for nonsurgical and minimal downtime facial rejuvenation has resulted in more use of injectable neurotoxins and fillers, andskinresurfacingandtighteningtreatments.Tis-sue heating either by radiofrequency (RF) or micro-focused ultrasound (MFU) can be part of the overall treatment  plan  to  tighten  skin  and  even  elevate facial structures. MFU generates heat in deeper dermis and subcutaneous tissue, leading to new collagen synthesis and subsequent skin tightening and elevation.</g></source><seg-source><g id="68"><mrk mtype="seg" mid="11">The continued patient demand for nonsurgical and minimal downtime facial rejuvenation has resulted in more use of injectable neurotoxins and fillers, andskinresurfacingandtighteningtreatments.Tis-sue heating either by radiofrequency (RF) or micro-focused ultrasound (MFU) can be part of the overall treatment  plan  to  tighten  skin  and  even  elevate facial structures.</mrk> <mrk mtype="seg" mid="12">MFU generates heat in deeper dermis and subcutaneous tissue, leading to new collagen synthesis and subsequent skin tightening and elevation.</mrk></g></seg-source><target><g id="68"><mrk mtype="seg" mid="11"/> <mrk mtype="seg" mid="12"/></g></target><sdl:seg-defs><sdl:seg id="11"><sdl:value key="SegmentIdentityHash">X5SNo5m5epHLa7mn6UMhj3aHH6zoduAIPQwjVLuZWAo=</sdl:value></sdl:seg><sdl:seg id="12"><sdl:value key="SegmentIdentityHash">CZZ8DcvLaBi0b7eaMZybTflRAuWLk401V9rGgztiZ9Q=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="15"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="9713b007-56dd-4a83-8ba0-6892d1a266dc"><source><g id="71">COLLAGEN DENATURATION AND NEOCOLLAGENESIS</g></source><seg-source><g id="71"><mrk mtype="seg" mid="13">COLLAGEN DENATURATION AND NEOCOLLAGENESIS</mrk></g></seg-source><target><g id="71"><mrk mtype="seg" mid="13"/></g></target><sdl:seg-defs><sdl:seg id="13"><sdl:value key="SegmentIdentityHash">e9knqtjZ/dfS80Mk5DwkLeZRBF1TlBwiRG+N0Qfwfb4=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="16"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="c58c6876-5bbc-472e-867b-bb38639476ad"><source><g id="78"><g id="74">When  collagen  is  exposed  to  60C  to  65C,  it becomes denatured.</g><g id="74"> </g><g id="74">One study showed that new collagen synthesis is observed after 30 days and another study showed new collagen and elastin synthesis at 10 weeks, along with deposition of new hyaluronic acid.</g><g id="77">1,2</g></g></source><seg-source><g id="78"><g id="74"><mrk mtype="seg" mid="14">When  collagen  is  exposed  to  60C  to  65C,  it becomes denatured.</mrk></g><g id="74"> </g><mrk mtype="seg" mid="15"><g id="74">One study showed that new collagen synthesis is observed after 30 days and another study showed new collagen and elastin synthesis at 10 weeks, along with deposition of new hyaluronic acid.</g><g id="77">1,2</g></mrk></g></seg-source><target><g id="78"><g id="74"><mrk mtype="seg" mid="14"/></g><g id="74"> </g><mrk mtype="seg" mid="15"/></g></target><sdl:seg-defs><sdl:seg id="14"><sdl:value key="SegmentIdentityHash">s9yVzuewmI6QR4JqirK01vFP5qN8cM4VEvk2yc16Fss=</sdl:value></sdl:seg><sdl:seg id="15"><sdl:value key="SegmentIdentityHash">lTOgHII2uiWPWUOZITqEoo/wfRp9tp/dbtLaj3rk0eA=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="17"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="bf9102cb-1320-424d-b80b-217263ee580a"><source><g id="81">MECHANISM OF ACTION</g></source><seg-source><g id="81"><mrk mtype="seg" mid="16">MECHANISM OF ACTION</mrk></g></seg-source><target><g id="81"><mrk mtype="seg" mid="16"/></g></target><sdl:seg-defs><sdl:seg id="16"><sdl:value key="SegmentIdentityHash">5EqWzLLDfxXoioIxBFc3humFCjX3CpUe02aseDoINgE=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="18"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="e662db2b-dc93-4455-ba18-33e3e03d0701"><source><g id="84">Ultrasound medical devices use sound waves for diagnostic imaging or medical treatments. Higher ultrasound frequencies have more superficial tis-sue  effects  and  lower  frequencies  have  deeper</g></source><seg-source><g id="84"><mrk mtype="seg" mid="17">Ultrasound medical devices use sound waves for diagnostic imaging or medical treatments.</mrk> <mrk mtype="seg" mid="18">Higher ultrasound frequencies have more superficial tis-sue  effects  and  lower  frequencies  have  deeper</mrk></g></seg-source><target><g id="84"><mrk mtype="seg" mid="17"/> <mrk mtype="seg" mid="18"/></g></target><sdl:seg-defs><sdl:seg id="17"><sdl:value key="SegmentIdentityHash">JG5K3PyF0zlGS9x1NEfG293ONUXiqfAaW1WqnyhC00E=</sdl:value></sdl:seg><sdl:seg id="18"><sdl:value key="SegmentIdentityHash">jsNXNbLGD5jnJsWimXcuhtREst1AABbLyvOHhszetoY=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="19"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="095d848d-cb62-4db2-ac40-d973d1e16d74"><source><x id="85"/></source><seg-source><x id="85"/></seg-source><target><x id="85"/></target></trans-unit></group><group><sdl:cxts><sdl:cxt id="20"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="f3d95a71-bfad-40f2-9543-90521b22387f"><source><g id="88">tissue effects. When ultrasound waves are micro-focused  to  a  point  in  living  tissue,  molecular vibration  results  and  heat  is  generated  creating well-defined   thermal  injury  zones  at  predeter-mined depths while leaving the surrounding tissue unaffected. At the resulting tissue temperatures, collagen  contraction,  and  denaturation  is  seen and neocollagenesis is stimulated.</g></source><seg-source><g id="88"><mrk mtype="seg" mid="19">tissue effects.</mrk> <mrk mtype="seg" mid="20">When ultrasound waves are micro-focused  to  a  point  in  living  tissue,  molecular vibration  results  and  heat  is  generated  creating well-defined   thermal  injury  zones  at  predeter-mined depths while leaving the surrounding tissue unaffected.</mrk> <mrk mtype="seg" mid="21">At the resulting tissue temperatures, collagen  contraction,  and  denaturation  is  seen and neocollagenesis is stimulated.</mrk></g></seg-source><target><g id="88"><mrk mtype="seg" mid="19"/> <mrk mtype="seg" mid="20"/> <mrk mtype="seg" mid="21"/></g></target><sdl:seg-defs><sdl:seg id="19"><sdl:value key="SegmentIdentityHash">nqImyNpheOYdOiI3TPKNcqugWtBwodNtsQEWHdpM81E=</sdl:value></sdl:seg><sdl:seg id="20"><sdl:value key="SegmentIdentityHash">uRWE+B0JUxUVxjN21jByD9ZGMa8x1Pw8Bn+CgFltBs0=</sdl:value></sdl:seg><sdl:seg id="21"><sdl:value key="SegmentIdentityHash">/WJHI6JsLtmGfwQlHb7x1ibUMDiLRGWzzmlIKpEnpc8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="21"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="674c3372-4336-4979-9772-c28442d8a720"><source><g id="91">MFU is different from RF energy in that it can be microfocused   to   target   deeper   tissue   without affecting more superficial tissue. Unlike RF energy, MFU can heat deeper tissue to between 60C and 70C without damaging the skin. For an RF device to achieve high temperatures, surface cooling is needed to protect the skin.</g></source><seg-source><g id="91"><mrk mtype="seg" mid="22">MFU is different from RF energy in that it can be microfocused   to   target   deeper   tissue   without affecting more superficial tissue.</mrk> <mrk mtype="seg" mid="23">Unlike RF energy, MFU can heat deeper tissue to between 60C and 70C without damaging the skin.</mrk> <mrk mtype="seg" mid="24">For an RF device to achieve high temperatures, surface cooling is needed to protect the skin.</mrk></g></seg-source><target><g id="91"><mrk mtype="seg" mid="22"/> <mrk mtype="seg" mid="23"/> <mrk mtype="seg" mid="24"/></g></target><sdl:seg-defs><sdl:seg id="22"><sdl:value key="SegmentIdentityHash">5ku2WGGqRIBau5cG5k2YG5Z0IdbYybdbmqlDn3ywBb8=</sdl:value></sdl:seg><sdl:seg id="23"><sdl:value key="SegmentIdentityHash">x530FxtBshDQ8W+TCNxRw+qDIIppkKssEMfl5T7U4LY=</sdl:value></sdl:seg><sdl:seg id="24"><sdl:value key="SegmentIdentityHash">f+XxWFaHiXL/bzgz9jy85kfQXnP0ypy/bfU3z2cTScw=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="22"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="02332c48-4d94-4ab6-8b44-585b1f8f3a81"><source><g id="94">ULTHERA MICROFOCUSED ULTRASOUND SYSTEM</g></source><seg-source><g id="94"><mrk mtype="seg" mid="25">ULTHERA MICROFOCUSED ULTRASOUND SYSTEM</mrk></g></seg-source><target><g id="94"><mrk mtype="seg" mid="25"/></g></target><sdl:seg-defs><sdl:seg id="25"><sdl:value key="SegmentIdentityHash">Ria+R4n6Dh0CVKjB10UjPkC3JCUlLXtYFaVNUz50opk=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="23"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="17eba54e-1d26-40c6-bf16-1f4d35aec3e2"><source><g id="97">The Ulthera system (Ultherapy) was approved by the US Food and Drug Administration in 2009 for noninvasive  eyebrow  elevation  but  is  routinely used  for  panfacial   and  submental  treatments. Depending on the device settings, the target tissue can be set to variable depths:</g></source><seg-source><g id="97"><mrk mtype="seg" mid="26">The Ulthera system (Ultherapy) was approved by the US Food and Drug Administration in 2009 for noninvasive  eyebrow  elevation  but  is  routinely used  for  panfacial   and  submental  treatments.</mrk> <mrk mtype="seg" mid="27">Depending on the device settings, the target tissue can be set to variable depths:</mrk></g></seg-source><target><g id="97"><mrk mtype="seg" mid="26"/> <mrk mtype="seg" mid="27"/></g></target><sdl:seg-defs><sdl:seg id="26"><sdl:value key="SegmentIdentityHash">sBC4Ykhr5n3uKkIowv102fn0X2BnAgX3AmsALmWyGng=</sdl:value></sdl:seg><sdl:seg id="27"><sdl:value key="SegmentIdentityHash">Tjs1FY/MYjQXurnw0UDMvvppTrR4ZceLGYauixnBFek=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="24"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="825180a2-eee9-4187-8a0e-2f964eed9059"><source><g id="100">  1.5 mm</g></source><seg-source><g id="100">  <mrk mtype="seg" mid="28">1.5 mm</mrk></g></seg-source><target><g id="100">  <mrk mtype="seg" mid="28"/></g></target><sdl:seg-defs><sdl:seg id="28"><sdl:value key="SegmentIdentityHash">NugNcoLIanOmX227JdmWKDqMf6YiPxWNPP8N9nN8Pg8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="25"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="c1bf95dc-114f-422a-b602-6589c054890f"><source><g id="103">  3.0 mm, which targets deep dermis</g></source><seg-source><g id="103">  <mrk mtype="seg" mid="29">3.0 mm, which targets deep dermis</mrk></g></seg-source><target><g id="103">  <mrk mtype="seg" mid="29"/></g></target><sdl:seg-defs><sdl:seg id="29"><sdl:value key="SegmentIdentityHash">sZjj8AO84Ih3NiQ4sDGq1v4uLGSi7RmgcsvpuCeriD8=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="26"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="2a799603-3c24-4344-b627-7e56019f9695"><source><g id="106">  4.5 mm, which targets the superficial muscular aponeurotic system (SMAS) and platysma</g></source><seg-source><g id="106">  <mrk mtype="seg" mid="30">4.5 mm, which targets the superficial muscular aponeurotic system (SMAS) and platysma</mrk></g></seg-source><target><g id="106">  <mrk mtype="seg" mid="30"/></g></target><sdl:seg-defs><sdl:seg id="30"><sdl:value key="SegmentIdentityHash">ygM3T/16Cu+ANmxbcVSmD17smkGWWYQ8gBpNURMfrgQ=</sdl:value></sdl:seg></sdl:seg-defs></trans-unit></group><group><sdl:cxts><sdl:cxt id="27"/><sdl:cxt id="2"/></sdl:cxts><trans-unit id="585c1b9d-f32d-41bb-9c4d-7c26dccac91c"><source><g id="109">Disclosures: The author does not have any financial interests or relationships with the product manufacturers. Division of Plastic Surgery, University of Illinois, 908 West Armitage, Chicago, IL 60614, USA</g></source><seg-source><g id="109"><mrk mtype="seg" mid="31">Disclosures:</mrk> <mrk mtype="seg" mid="32">The author does not have any financial interests or relationships with the product manufacturers.</mrk> <mrk mtype="seg" mid="33">Division of Plastic Surgery, University of Illinois, 908 West Armitage, Chicago, IL 60614, USA</mrk></g></seg-source><target><g id="109"><mrk mtype="seg" mid="31"/> <mrk mtype="seg" mid="32"/> <mrk mtype="seg" mid="33"/></g></target><sdl:seg-defs><sdl:seg id="31"><sdl:value key="SegmentIdentityHash">ofeDjVwGEPj/+09Ymt02BBrZ6HKkF1rWNKYg8yZGOPo=</sdl:value></sdl:seg><sdl:seg id="32"><sdl:value key="Segmen